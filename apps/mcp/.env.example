# --- Git provider ---
VIBECHECK_PROVIDER=github            # github (default) | gitlab

# GitHub (default provider)
GITHUB_TOKEN=ghp_xxx                 # PAT or fine-grained token (contents: write, pull_requests: write)
GITHUB_REPO=your-org/your-site       # owner/name of the site repo
GITHUB_DEFAULT_BRANCH=main
# GITHUB_API_URL=https://api.github.com   # set for GitHub Enterprise

# GitLab (only when VIBECHECK_PROVIDER=gitlab)
# GITLAB_TOKEN=glpat_xxx
# GITLAB_PROJECT_ID=12345
# GITLAB_DEFAULT_BRANCH=main
# GITLAB_API_URL=https://gitlab.com/api/v4

# --- Content paths (defaults assume the site is at the repo root) ---
# If the MCP edits a monorepo where the site lives under apps/site, set:
#   VIBECHECK_PAGES_DIR=apps/site/src/content/pages
#   VIBECHECK_POSTS_DIR=apps/site/src/content/blog
#   VIBECHECK_REDIRECTS_PATH=apps/site/public/_redirects
# VIBECHECK_PAGES_DIR=src/content/pages
# VIBECHECK_POSTS_DIR=src/content/blog
# VIBECHECK_REDIRECTS_PATH=public/_redirects

# --- Server ---
PORT=8787
MCP_AUTH_TOKEN=change-me-to-a-long-random-secret   # clients send this as the Bearer token
# PUBLIC_URL=https://your-mcp-host.example.com       # public base URL when hosted behind HTTPS
