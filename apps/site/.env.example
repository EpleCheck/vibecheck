# Integration endpoints — see apps/site/src/lib/integrations.ts
#
# A `form` section references an integration by name (e.g. `integration: contact`).
# These vars set where each one POSTs. They're read at build time and end up in the
# rendered HTML form `action`, so they are NOT secret — they're just deploy-specific
# URLs. True secrets (API keys, auth) live in the receiving service, never here.
#
# Each has a safe local default in integrations.ts, so the build works without this
# file. Set these to point at your real hosted form service or function.

# Contact form target (on EpleCheck: the existing contact webhook URL).
CONTACT_ENDPOINT=/api/contact

# Newsletter signup target (e.g. a Buttondown/Brevo form action URL).
NEWSLETTER_ENDPOINT=/api/newsletter
